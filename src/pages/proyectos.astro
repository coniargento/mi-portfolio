<style>

    .proyectos {
      padding: 5rem 3rem;
    }
  
    /* Encabezado igual al de sobre mí */
    .proy-header {
      text-align: center;
      margin-bottom: 4rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
  
    .proy-vol {
      font-family: 'Poppins', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      color: var(--muted);
      text-transform: uppercase;
    }
  
    .proy-titulo {
      font-family: 'Anton', sans-serif;
      font-size: clamp(4rem, 10vw, 8rem);
      line-height: 1;
      letter-spacing: -0.02em;
    }
  
    .proy-subtitulo {
      font-family: 'DM Serif Display', serif;
      font-style: italic;
      font-size: 1.2rem;
      color: var(--muted);
    }
  
    .proyecto {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      padding: 3rem 0;
      border-top: 1px solid rgba(0,0,0,0.15);
      align-items: center;
    }
  
    /* Proyecto invertido — imagen a la derecha */
    .proyecto-invertido .proyecto-img {
      order: 2;
    }
  
    .proyecto-invertido .proyecto-info {
      order: 1;
    }

    .proyecto-img {
      width: 100%;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border: 1.5px solid var(--negro);
    }
  
    .proyecto-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
  
    .proyecto-img:hover img {
      transform: scale(1.04);
    }
  
    .proyecto-img-placeholder {
      background: #e8e4de;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  
    .proyecto-img-placeholder span {
      font-family: 'Poppins', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      color: #aaa;
      text-transform: uppercase;
    }
  
    .proyecto-info {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
  
    .proyecto-num {
      font-family: 'Anton', sans-serif;
      font-size: 3rem;
      line-height: 1;
      color: var(--rosa);
      opacity: 0.3;
    }
  
    .proyecto-label {
      font-family: 'Poppins', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      color: var(--rosa);
      text-transform: uppercase;
    }
  
    .proyecto-nombre {
      font-family: 'Anton', sans-serif;
      font-size: 2rem;
      line-height: 1.1;
    }
  
    .proyecto-desc {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--muted);
    }
  
    /* Tags de tecnologías */
    .proyecto-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.3rem;
    }
  
    .ptag {
      background: transparent;
      color: var(--negro);
      font-family: 'Poppins', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1.5px solid var(--negro);
    }
  
    /* Link al proyecto */
    .proyecto-link {
      margin-top: 0.5rem;
      display: inline-block;
      font-family: 'Poppins', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--negro);
      text-decoration: none;
      border-bottom: 2px solid var(--rosa);
      width: fit-content;
      transition: color 0.2s, border-color 0.2s;
    }
  
    .proyecto-link:hover {
      color: var(--rosa);
    }
  </style>