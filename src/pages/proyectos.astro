---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Proyectos — Coni Argento">

    <section class="proyectos" id="proyectos">
        <div class="proy-header">
          <div class="proy-vol">VOL. 02 — TRABAJOS</div>
          <h2 class="proy-titulo">PROYECTOS</h2>
          <div class="proy-subtitulo">Lo que hice, lo que aprendí, lo que me enorgullece</div>
        </div>
      
        <!-- PROYECTO 1 -->
        <article class="proyecto">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://cafeboxd.vercel.app/" target="_blank" class="footer-link">
              <img src="/proyecto1.jpeg" alt="cafeboxd" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">01</div>
            <div class="proyecto-label">2025</div>
            <h3 class="proyecto-nombre">CAFEBOXD</h3>
            <p class="proyecto-desc">
              Un espacio digital para encontrar nuevos cafecitos
            </p>
            <div class="proyecto-tags">
              <span class="ptag">HTML</span>
              <span class="ptag">CSS</span>
              <span class="ptag">JS</span>
              <span class="ptag">ASTRO</span>
            </div>
            <a href="https://cafeboxd.vercel.app/" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>
      
        <!-- PROYECTO 2 -->
        <article class="proyecto proyecto-invertido">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://www.behance.net/gallery/158015023/Mi-caf-App" target="_blank" class="footer-link">
              <img src="/portada-micafe.jpg" alt="mistika" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">02</div>
            <div class="proyecto-label">DISEÑO UX/UI · 2022</div>
            <h3 class="proyecto-nombre">MI CAFÉ</h3>
            <p class="proyecto-desc">
              ¡Mi cafe! es una aplicación que le facilita a los usuarios encontrar donde ir a tomar cafe y así no tengan que caer siempre en el mismo lugar por no conocer otras opciones
            </p>
            <div class="proyecto-tags">
              <span class="ptag">Figma</span>
              <span class="ptag">Illustrator</span>
              <span class="ptag">UX/UI</span>
              <span class="ptag">Investigación</span>
            </div>
            <a href="https://www.behance.net/gallery/158015023/Mi-caf-App" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>

        <!-- PROYECTO 3 -->
        <article class="proyecto">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://ecommerce-prg3-24.vercel.app/" target="_blank" class="footer-link">
              <img src="/portada-ecommerce.jpeg" alt="cafeboxd" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">03</div>
            <div class="proyecto-label">2024</div>
            <h3 class="proyecto-nombre">ECOMMERCE</h3>
            <div class="proyecto-tags">
              <span class="ptag">HTML</span>
              <span class="ptag">CSS</span>
              <span class="ptag">JS</span>
            </div>
            <a href="https://ecommerce-prg3-24.vercel.app/" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>
      
        <!-- PROYECTO 4 -->
        <article class="proyecto proyecto-invertido">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://www.behance.net/gallery/206229277/INVESTIGACION-UX" target="_blank" class="footer-link">
              <img src="/portada-investigacion.jpeg" alt="investigacionux" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">04</div>
            <div class="proyecto-label">INVESTIGACIÓN UX · 2023</div>
            <h3 class="proyecto-nombre">"FLYBENDI"-CASO DE ESTUDIO</h3>
            <p class="proyecto-desc">
              A lo largo del cuatrimestre en la materia Técnicas de Investigación de UX empezamos a investigar la relación que tienen los niños con la tecnología.
              Así que así empezó todo, realizando una investigación de escritorio en la que fuimos notando las emociones que causaba la tecnología en los niños.
              De ahí se creo una app que ayuda a las familias a encontrar actividades recreativas para sus hijos, apuntando a convertirse en el sustituto del boca a
              boca y la publicidad barrial de eventos infantiles, pero principalmente con un enfoque en lograr que los niños hagan más actividades no digitales.
            </p>
            <div class="proyecto-tags">
              <span class="ptag">Figma</span>
              <span class="ptag">UX/UI</span>
              <span class="ptag">testeos</span>
              <span class="ptag">Investigación</span>
            </div>
            <a href="https://www.behance.net/gallery/206229277/INVESTIGACION-UX" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>

        <!-- PROYECTO 5 -->
        <article class="proyecto">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://www.behance.net/gallery/191937597/Diseno-para-redes-sociales-Torneo-de-futbol/" target="_blank" class="footer-link">
              <img src="/portada-torneo.jpeg" alt="ligadelsur" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">05</div>
            <div class="proyecto-label">2023</div>
            <h3 class="proyecto-nombre">TORNEO LIGA DEL SUR</h3>
            <p class="proyecto-desc">
              Desarrollo de manual de identidad para las redes sociales del torneo de fútbol + placas para utilizar.
            </p>
            <div class="proyecto-tags">
              <span class="ptag">DISEÑO</span>
              <span class="ptag">FIGMA</span>
              <span class="ptag">ILLUSTRATOR</span>
              <span class="ptag">REDES SOCIALES</span>
            </div>
            <a href="https://www.behance.net/gallery/191937597/Diseno-para-redes-sociales-Torneo-de-futbol" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>
      
        <!-- PROYECTO 6 -->
        <article class="proyecto proyecto-invertido">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://www.behance.net/gallery/192332377/Proyecto-de-estructura-ludica" target="_blank" class="footer-link">
              <img src="/portada-mistika.jpeg" alt="mistika" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">06</div>
            <div class="proyecto-label">DISEÑO LÚDICO · 2024</div>
            <h3 class="proyecto-nombre">MISTIKA</h3>
            <p class="proyecto-desc">
              Mistika es un juego sobre el tarot para divertirte con tus amigos y aprender más sobre el significado de las míticas cartas del tarot.
            </p>
            <div class="proyecto-tags">
              <span class="ptag">Figma</span>
              <span class="ptag">Illustrator</span>
            </div>
            <a href="https://www.behance.net/gallery/192332377/Proyecto-de-estructura-ludica" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>

        <!-- PROYECTO 7 -->
        <article class="proyecto">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://simulador-de-latte-art.vercel.app/" target="_blank" class="footer-link">
              <img src="/portada-simulador.jpeg" alt="simulador-latte-art" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">07</div>
            <div class="proyecto-label">2025</div>
            <h3 class="proyecto-nombre">SIMULADOR DE LATTE ART</h3>
            <p class="proyecto-desc">
              Simulador gamificado de latte art-Resolver la dificultad que enfrentan los baristas principiantes a
              aprender latte art, mediante el desarrollo de un simulador digital que permita experimentar el movimiento
              y la técnica del vertido sin necesidad de utilizar leche ni café y así disminuir el desperdicio de recursos.
            </p>
            <div class="proyecto-tags">
              <span class="ptag">HTML</span>
              <span class="ptag">CSS</span>
              <span class="ptag">JS</span>
              <span class="ptag">ASTRO</span>
            </div>
            <a href="https://simulador-de-latte-art.vercel.app/" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>
      
        <!-- PROYECTO 8 -->
        <article class="proyecto proyecto-invertido">
          <div class="proyecto-img proyecto-img-placeholder">
            <a href="https://pagina-web-juco.vercel.app/" target="_blank" class="footer-link">
              <img src="/portada-agencia.jpeg" alt="pagina-juco" />
            </a>
          </div>
          <div class="proyecto-info">
            <div class="proyecto-num">08</div>
            <div class="proyecto-label">DISEÑO WEB · 2026</div>
            <h3 class="proyecto-nombre">PÁGINA WEB AGENCIA</h3>
            <p class="proyecto-desc">
              Este es mi proyecto actual que esta en desarrollo... :)
            <div class="proyecto-tags">
              <span class="ptag">HTML</span>
              <span class="ptag">CSS</span>
              <span class="ptag">JS</span>
              <span class="ptag">ASTRO</span>
            </div>
            <a href="https://pagina-web-juco.vercel.app/" target="_blank" class="proyecto-link">Ver proyecto →</a>
          </div>
        </article>
      
      </section>

      <Footer />

</Layout>

<style>
    .proyectos {
      padding: 5rem 3rem;
    }

    .proy-header {
      text-align: center;
      margin-bottom: 4rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
  
    .proy-vol {
      font-family: 'Poppins', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      color: var(--muted);
      text-transform: uppercase;
    }
  
    .proy-titulo {
      font-family: 'Anton', sans-serif;
      font-size: clamp(4rem, 10vw, 8rem);
      line-height: 1;
      letter-spacing: -0.02em;
    }
  
    .proy-subtitulo {
      font-family: 'DM Serif Display', serif;
      font-style: italic;
      font-size: 1.2rem;
      color: var(--muted);
    }
  
    .proyecto {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      padding: 3rem 0;
      border-top: 1px solid rgba(0,0,0,0.15);
      align-items: center;
    }

    .proyecto-invertido .proyecto-img {
      order: 2;
    }
  
    .proyecto-invertido .proyecto-info {
      order: 1;
    }

    .proyecto-img {
      width: 100%;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border: 1.5px solid var(--negro);
    }

    .proyecto-img a {
      display: block;
      width: 100%;
      height: 100%;
    }

    .proyecto-img a img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
  
    .proyecto-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
  
    .proyecto-img:hover img {
      transform: scale(1.04);
    }
  
    .proyecto-img-placeholder {
      background: #e8e4de;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  
    .proyecto-img-placeholder span {
      font-family: 'Poppins', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      color: #aaa;
      text-transform: uppercase;
    }
  
    .proyecto-info {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
  
    .proyecto-num {
      font-family: 'Anton', sans-serif;
      font-size: 3rem;
      line-height: 1;
      color: var(--rosa);
      opacity: 0.3;
    }
  
    .proyecto-label {
      font-family: 'Poppins', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      color: var(--rosa);
      text-transform: uppercase;
    }
  
    .proyecto-nombre {
      font-family: 'Anton', sans-serif;
      font-size: 2rem;
      line-height: 1.1;
    }
  
    .proyecto-desc {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--muted);
    }
  
    .proyecto-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.3rem;
    }
  
    .ptag {
      background: transparent;
      color: var(--negro);
      font-family: 'Poppins', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      border: 1.5px solid var(--negro);
    }
  
    .proyecto-link {
      margin-top: 0.5rem;
      display: inline-block;
      font-family: 'Poppins', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--negro);
      text-decoration: none;
      border-bottom: 2px solid var(--rosa);
      width: fit-content;
      transition: color 0.2s, border-color 0.2s;
    }
  
    .proyecto-link:hover {
      color: var(--rosa);
    }

    /* ============================
     RESPONSIVE
    ============================= */
    @media (max-width: 768px) {
    .proyectos {
      padding: 3rem 1.5rem;
    }

    /* Cada proyecto pasa a una sola columna */
    .proyecto {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
    }

    /* Proyecto invertido vuelve al orden normal */
    .proyecto-invertido .proyecto-img { order: 1; }
    .proyecto-invertido .proyecto-info { order: 2; }
    }
  </style>