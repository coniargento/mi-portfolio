---
// Página principal del portfolio
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio — Coni Argento">

  <section class="hero">

    <!-- Texto de la izquierda -->
    <div class="hero-contenido">
      <div class="hero-tag">✦ Disponible para proyectos</div>
      <h1>Hola, soy <em>Coni</em> —<br> creo experiencias<br>digitales que se viven.</h1>
      <p>
		Estudiante de <mark>Tecnología Multimedial</mark> apasionada por el <mark>diseño</mark>, las <mark>interfaces</mark> y la <mark>creatividad</mark>. Hoy en día tengo una <mark>agencia creativa</mark> donde se desarrollan proyectos y ofrecen <mark>soluciones digitales</mark>.
	  </p>
      <a href="#proyectos" class="boton">Ver mis proyectos →</a>
    </div>

    <!-- Licencia de la derecha -->
	<div class="licencia-wrap">
		<div class="tag-scene">
		  <img class="clip-negro" src="/clip.png" alt="clip" />
		  <div class="tag-card">
	  
			<!-- FRENTE -->
			<div class="tag-frente">
			  <div class="tag-agencia">CONI ARGENTO</div>
			  <div class="tag-subtitulo">AGENCIA CREATIVA</div>
			  <div class="tag-fecha">2003 — HOY</div>
			  <div class="tag-foto">
				<img src="/foto-portfolio.png" alt="Coni" />
			  </div>
			  <div class="tag-nombre">CONI</div>
			  <div class="tag-rol">ESTUDIANTE DE TECNOLOGÍA MULTIMEDIAL</div>
			</div>
	  
			<!-- DORSO -->
			<div class="tag-dorso">
			  <div class="tag-nombre-grande">CONI</div>
			  <div class="tag-rol-dorso">ESTUDIANTE DE TEC. MULTIMEDIAL</div>
			  <div class="tag-separador"></div>
			  <div class="tag-frase">
				EL DISEÑO NO ES SOLO ESTÉTICA, ES CONEXIÓN.
			  </div>
			  <div class="tag-frase">
				CREO COSAS QUE LAS PERSONAS NO SOLO VEN: LAS SIENTEN.
			  </div>
			  <div class="tag-separador"></div>
			  <div class="tag-gracias">Gracias por su visita.</div>
			</div>
	  
		  </div>
		</div>
	  </div>

    <!-- Nombre gigante abajo -->
	<div class="nombre-gigante">
		<div class="nombre-track">
		  <span>CONI ARGENTO &nbsp;✦&nbsp; </span>
		  <span>CONI ARGENTO &nbsp;✦&nbsp; </span>
		  <span>CONI ARGENTO &nbsp;✦&nbsp; </span>
		</div>
	  </div>

  </section>

</Layout>

<style>
  /* ---- HERO ---- */
  .hero {
  padding: 0 0 0 3rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr auto;
  min-height: 90vh;
}

  /* ---- TEXTO IZQUIERDA ---- */
  .hero-contenido {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 10rem 0 2rem;
}

  .hero-tag {
    display: inline-block;
    background: var(--amarillo);
    border: 2px solid var(--negro);
    border-radius: 999px;
    padding: 0.3rem 1rem;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    width: fit-content;
    transform: rotate(-2deg);
  }

  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1.15;
  }

  h1 em {
    font-style: italic;
    color: var(--rosa);
  }

  p {
  margin-top: 1.2rem;
  font-size: 1rem;
  color: var(--muted);
  max-width: 100%;
  line-height: 1.6;
}

mark {
  background: var(--amarillo);
  color: #111;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-style: normal;
}

  .boton {
    margin-top: 2rem;
    display: inline-block;
    background: var(--negro);
    color: var(--bg);
    padding: 0.8rem 1.8rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    width: fit-content;
    transition: background 0.2s, transform 0.2s;
  }

  .boton:hover {
    background: var(--rosa);
    transform: scale(1.08) rotate(-1deg);
  }

  /* ---- ETIQUETA ---- */
  .licencia-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: colgar 3s ease-in-out infinite;
    transform-origin: top center;
    position: relative;
    z-index: 200;
  }

  @keyframes colgar {
    0%, 100% { transform: rotate(-1.5deg); }
    50%       { transform: rotate(1.5deg); }
  }

  /* Clip negro arriba */
  .clip-negro {
    width: 100px;
    position: absolute;
    top: -95px;
    left: 55%;
    transform: translateX(-50%);
    z-index: 300;
  }

  /* Escena 3D */
  .tag-scene {
    width: 240px;
    height: 480px;
    perspective: 900px;
    cursor: pointer;
    margin-top: 0px;
  }

  .tag-card {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform: rotate(2deg);
    filter: drop-shadow(4px 8px 16px rgba(0,0,0,0.2));
  }

  .tag-scene:hover .tag-card {
    transform: rotate(0deg) rotateY(180deg);
  }

  .tag-frente,
  .tag-dorso {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    background: #f0ede8;
    border: 1.5px solid #ccc;
    font-family: 'Anton', sans-serif;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.3rem;
  }

  .tag-dorso {
    transform: rotateY(180deg);
  }

  /* FRENTE */
  .tag-agencia {
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    color: #111;
    line-height: 1;
  }

  .tag-subtitulo {
    font-family: 'Poppins', sans-serif;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #555;
    text-transform: uppercase;
  }

  .tag-fecha {
    font-family: 'Poppins', sans-serif;
    font-size: 0.55rem;
    color: #888;
    letter-spacing: 0.1em;
    margin-bottom: 0.3rem;
  }

  .tag-foto {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border: 1.5px solid #ccc;
  }

  .tag-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .tag-nombre {
    font-size: 2.8rem;
    color: #111;
    line-height: 1;
    margin-top: 0.3rem;
  }

  .tag-rol {
    font-family: 'Poppins', sans-serif;
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #555;
    text-transform: uppercase;
  }

  /* DORSO */
  .tag-nombre-grande {
    font-size: 3.5rem;
    color: #111;
    line-height: 1;
  }

  .tag-rol-dorso {
    font-family: 'Poppins', sans-serif;
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #555;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .tag-separador {
    border-top: 1.5px dashed #aaa;
    margin: 0.4rem 0;
  }

  .tag-frase {
    font-family: 'Poppins', sans-serif;
    font-size: 0.62rem;
    color: #333;
    line-height: 1.5;
    letter-spacing: 0.05em;
    text-align: justify;
  }

  .tag-gracias {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 0.85rem;
    color: #555;
    margin-top: auto;
  }

  /* ---- NOMBRE GIGANTE ---- */
  .nombre-row {
    grid-column: 1 / -1;
  }

  .nombre-gigante {
  grid-column: 1 / -1;
  font-family: 'Anton', sans-serif;
  font-size: clamp(3rem, 12vw, 10rem);
  line-height: 0.9;
  white-space: nowrap;
  overflow: hidden;
  letter-spacing: -0.02em;
}

.nombre-track {
  display: flex;
  width: max-content;
  animation: ticker 8s linear infinite;
}

@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-33.33%); }
}
</style>