---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio — Coni Argento">

  <section class="hero">

    <div class="hero-contenido">
      <div class="hero-tag">✦ Disponible para proyectos</div>
      <h1>Hola, soy <em>Coni</em> —<br> creo experiencias<br>digitales que se viven.</h1>
      <p>
		Estudiante de <mark>Tecnología Multimedial</mark> apasionada por el <mark>diseño</mark>, las <mark>interfaces</mark> y la <mark>creatividad</mark>. Hoy en día tengo una <mark>agencia creativa</mark> donde se desarrollan proyectos y ofrecen <mark>soluciones digitales</mark>.
	  </p>
      <a href="/proyectos" class="boton">Ver mis proyectos →</a>
    </div>

<div class="hero-foto">
  <div class="foto-wrap">
    <img src="/camara.png" alt="Coni Argento" />

    <div class="sticker s1"><img src="/2.png" alt="lineas" /></div>
    <div class="sticker s3">cafe 24/7</div>
    <div class="sticker s4">✦ creativa</div>
    <div class="sticker s5"><img src="/4.png" alt="sonrisa" /></div>
    <div class="sticker s6">rosa siempre</div>
    <div class="sticker s7"><img src="/3.png" alt="estrellas" /></div>
    <div class="sticker s8">✨</div>
  </div>
</div>

	<div class="nombre-gigante">
		<div class="nombre-track">
		  <span>CONI ARGENTO &nbsp;✦&nbsp; </span>
		  <span>CONI ARGENTO &nbsp;✦&nbsp; </span>
		  <span>CONI ARGENTO &nbsp;✦&nbsp; </span>
		</div>
	  </div>

  </section>

</Layout>

<style>
  .hero {
  padding: 0 0 0 3rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr auto;
  min-height: 90vh;
}

  .hero-contenido {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 10rem 0 2rem;
}

  .hero-tag {
    display: inline-block;
    background: #fe91cf; 
    border: 2px solid var(--negro);
    border-radius: 999px;
    padding: 0.3rem 1rem;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    width: fit-content;
    transform: rotate(-2deg);
  }

  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1.15;
  }

  h1 em {
    font-style: italic;
    color: var(--rosa);
  }

  p {
  margin-top: 1.2rem;
  font-size: 1rem;
  color: var(--muted);
  max-width: 100%;
  line-height: 1.6;
}

mark {
  background: #fe91cf; 
  color: #111;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-style: normal;
}

  .boton {
    margin-top: 2rem;
    display: inline-block;
    background: var(--negro);
    color: var(--bg);
    padding: 0.8rem 1.8rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    width: fit-content;
    transition: background 0.2s, transform 0.2s;
  }

  .boton:hover {
    background: var(--rosa);
    transform: scale(1.08) rotate(-1deg);
  }

  @keyframes colgar {
    0%, 100% { transform: rotate(-1.5deg); }
    50%       { transform: rotate(1.5deg); }
  }

  /* Escena 3D */
  .tag-scene {
    width: 240px;
    height: 480px;
    perspective: 900px;
    cursor: pointer;
    margin-top: 0px;
  }

  .tag-card {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform: rotate(2deg);
    filter: drop-shadow(4px 8px 16px rgba(0,0,0,0.2));
  }

  .tag-scene:hover .tag-card {
    transform: rotate(0deg) rotateY(180deg);
  }

  .tag-frente,
  .tag-dorso {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    background: #f0ede8;
    border: 1.5px solid #ccc;
    font-family: 'Anton', sans-serif;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.3rem;
  }

  .tag-dorso {
    transform: rotateY(180deg);
  }

  /* FRENTE */
  .tag-agencia {
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    color: #111;
    line-height: 1;
  }

  .tag-subtitulo {
    font-family: 'Poppins', sans-serif;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #555;
    text-transform: uppercase;
  }

  .tag-fecha {
    font-family: 'Poppins', sans-serif;
    font-size: 0.55rem;
    color: #888;
    letter-spacing: 0.1em;
    margin-bottom: 0.3rem;
  }

  .tag-foto {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border: 1.5px solid #ccc;
  }

  .tag-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .tag-nombre {
    font-size: 2.8rem;
    color: #111;
    line-height: 1;
    margin-top: 0.3rem;
  }

  .tag-rol {
    font-family: 'Poppins', sans-serif;
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #555;
    text-transform: uppercase;
  }

  /* DORSO */
  .tag-nombre-grande {
    font-size: 3.5rem;
    color: #111;
    line-height: 1;
  }

  .tag-rol-dorso {
    font-family: 'Poppins', sans-serif;
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #555;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .tag-separador {
    border-top: 1.5px dashed #aaa;
    margin: 0.4rem 0;
  }

  .tag-frase {
    font-family: 'Poppins', sans-serif;
    font-size: 0.62rem;
    color: #333;
    line-height: 1.5;
    letter-spacing: 0.05em;
    text-align: justify;
  }

  .tag-gracias {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 0.85rem;
    color: #555;
    margin-top: auto;
  }

  /* mi nombre gigante que se mueve jajajaja*/
  .nombre-row {
    grid-column: 1 / -1;
  }

  .nombre-gigante {
  grid-column: 1 / -1;
  font-family: 'Anton', sans-serif;
  font-size: clamp(3rem, 12vw, 10rem);
  line-height: 0.9;
  white-space: nowrap;
  overflow: hidden;
  letter-spacing: -0.02em;
}

.nombre-track {
  display: flex;
  width: max-content;
  animation: ticker 8s linear infinite;
}

@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-33.33%); }
}

.hero-foto {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-foto img {
    width: 100%;
    max-width: 450px;
    display: block;
    animation: polaroid 1s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
  }

  @keyframes polaroid {
    from {
      opacity: 0;
      transform: scale(0.8) rotate(-8deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(-2deg);
    }
  }

  .foto-wrap {
    position: relative;
    width: fit-content;
  }

  .sticker {
    position: absolute;
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--negro);
    background: var(--amarillo);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    border: 1.5px solid var(--negro);
    white-space: nowrap;
    animation: aparecer 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .sticker img {
    width: 150px;
    height: 150px;
    object-fit: contain;
  }

  /* Posición de cada sticker */
  .s1 { top: -40px;  left: -50px;  transform: rotate(-12deg); animation-delay: 0.8s;  font-size: 1.4rem; background: transparent; border: none; }
  .s2 { top: 20px;   left: -50px;  transform: rotate(-6deg);  animation-delay: 1s;    font-size: 1.4rem; background: transparent; border: none; }
  .s3 { top: -20px;  right: 20px;  transform: rotate(8deg);   animation-delay: 0.9s;  background: #b87959; color: white; }
  .s4 { bottom: 60px; left: -60px; transform: rotate(-8deg);  animation-delay: 1.1s; background: #8abbdb; color: white; }
  .s5 { bottom: -20px; right: -60px; transform: rotate(6deg);  animation-delay: 1.2s;  font-size: 1.4rem; background: transparent; border: none; }
  .s6 { top: 50px;   right: -65px; transform: rotate(10deg);  animation-delay: 1.3s;  background: #fe91cf; color: white; }
  .s7 { bottom: -50px; left: -50px; transform: rotate(-4deg);  animation-delay: 1.4s;  font-size: 1.4rem; background: transparent; border: none; }
  .s8 { top: 100px;  left: -40px;  transform: rotate(5deg);   animation-delay: 1.5s;  font-size: 1.2rem; background: transparent; border: none; }

  @keyframes aparecer {
    from { opacity: 0; transform: scale(0) rotate(-20deg); }
    to   { opacity: 1; }
  }
  
/* ============================
     RESPONSIVE
  ============================= */
  @media (max-width: 768px) {

    nav {
      padding: 1rem 1.5rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    a {
      font-size: 0.5rem;
    }   

.hero {
  grid-template-columns: 1fr;
  padding: 0 1.5rem;
  min-height: auto;
}

.hero-contenido {
  padding: 2rem 0 1.5rem;
}

.hero-foto {
  justify-content: center;
  padding: 1rem 0;
}

.hero-foto img {
  max-width: 280px;
}

.sticker {
  font-size: 0.65rem;
  padding: 0.2rem 0.5rem;
}

.s1, .s2, .s5, .s7, .s8 { font-size: 1rem; }

.nombre-gigante {
  font-size: clamp(2.5rem, 10vw, 5rem);
}

.nombre-row {
  grid-column: 1;
}

}

</style>