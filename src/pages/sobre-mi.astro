          <div class="tl-controles">
            <button class="tl-btn" onclick="mover(this,-1)">←</button>
            <div class="tl-dots">
              <div class="tl-dot activo"></div>
              <div class="tl-dot"></div>
              <div class="tl-dot"></div>
              <div class="tl-dot"></div>
              <div class="tl-dot"></div>
              <div class="tl-dot"></div>
              <div class="tl-dot"></div>
            </div>
            <button class="tl-btn" onclick="mover(this,1)">→</button>
